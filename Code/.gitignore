## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Mono Auto Generated Files
mono_crash.*

# VS Code
.vscode/

# Windows image file caches
Thumbs.db
ehthumbs.db

# JetBrains Rider
.idea/

# NuGet packages
*.nupkg
*.snupkg
packages/
*.nuspec

# DotCover
*.dotCover

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Publish output
publish/
*.Publish.xml

# NPM packages
node_modules/

# Others
*.log
*.tlog
*.cache
*.vspscc
*.vssscc
*.pdb
*.dbmdl

# Visual Studio
.vs/

# Sensitive configuration files - DO NOT COMMIT
appsettings.Development.json
appsettings.Production.json
**/secrets.json
**/*.local.json

# 🔒 SECURITY - Never commit these
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
.env
.env.*
!.env.example
**/appsettings.*.json
!**/appsettings.json

# User Secrets
secrets/

# SSL/TLS certificates
**/https/*.pem
**/https/*.key

# Database files
*.db
*.sqlite
*.sqlite3

# Logs that might contain sensitive info
logs/
*.log
